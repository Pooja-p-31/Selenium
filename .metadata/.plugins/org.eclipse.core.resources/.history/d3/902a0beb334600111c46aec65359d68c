public class Assignment_03 {

	/*
	 * 1. Launch Chrome browser
	   2. Open https://demo.nopcommerce.com/
	   3. Validate the title ("nopCommerce demo store. Home page title")
  	   4. Find the Search box on the page and type something into it (e.g. "Apple")
	   5. Click the Search button
	   6. Validate that the new page title contains the word "Search" or your search term
	   7. Close the browser
	 * 
	 */
	
	public static void main(String[] args) {
		WebDriver driver = new ChromeDriver();
		driver.get("https://demo.nopcommerce.com/");
		String actual_result = driver.getTitle();
		if (actual_result.equals("nopCommerce demo store. Home page title")) 
		{
			System.out.println("Correct");
		}
		else {
			System.out.println("Incorrect");
		}
		driver.findElement(By.id("small-searchterms"));
		
		WebElement searchBox = driver.findElement(By.id("small-searchterms"));
		searchBox.sendKeys("Apple");
		
		WebElement searchbtn = driver.findElement(By.id("small-searchterms"));
		searchbtn.click();
		
	    String search_page_titleString = driver.getTitle();
	    
		if (search_page_titleString.contains("Search")) 
		{
			System.out.println("Search Page Title - Correct");
			
		}
		else {
			System.out.println("Search Page Title - Incorrect");
		}

	}

}
